{% if books is empty %}
    {% if app.request.query.get('q') %}
        <p class="text-center text-gray-500 py-8">Aucun résultat trouvé.</p>
    {% endif %}
{% else %}
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
    {% for book in books %}
    <div class="bg-white rounded-lg overflow-hidden shadow-md flex flex-col">
        {% if book.cover_i is defined %}
            <img src="https://covers.openlibrary.org/b/id/{{ book.cover_i }}-M.jpg" alt="" class="w-full h-52 object-contain bg-gray-100" loading="lazy">
        {% else %}
            <div class="w-full h-52 bg-gray-100 flex items-center justify-center text-gray-400 text-sm">Pas de couverture</div>
        {% endif %}
        <div class="p-4 flex-1 flex flex-col">
            <h3 class="font-semibold text-base mb-1">{{ book.title }}</h3>
            {% if book.author_name is defined %}
                <p class="text-gray-600 text-sm">{{ book.author_name|join(', ') }}</p>
            {% endif %}
            {% if book.first_publish_year is defined %}
                <p class="text-gray-400 text-xs mt-1">{{ book.first_publish_year }}</p>
            {% endif %}
            <div class="mt-auto pt-3">
                <button
                    type="button"
                    data-action="book-search#add"
                    data-book-title="{{ book.title }}"
                    data-book-author="{{ book.author_name is defined ? book.author_name|join(', ') : '' }}"
                    data-book-year="{{ book.first_publish_year is defined ? book.first_publish_year : '' }}"
                    data-book-cover-url="{{ book.cover_i is defined ? 'https://covers.openlibrary.org/b/id/' ~ book.cover_i ~ '-M.jpg' : '' }}"
                    data-book-key="{{ book.key }}"
                    class="w-8 h-8 rounded-full bg-blue-500 text-white hover:bg-blue-700 hover:scale-110 active:scale-95 transition-all duration-150 flex items-center justify-center cursor-pointer"
                >{{ ux_icon('lucide:plus', {class: 'w-4 h-4'}) }}</button>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
