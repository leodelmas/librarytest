<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>Bibliothèque - Inscription</title>
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="min-h-screen flex items-center justify-center bg-gray-100">
        <div class="w-full max-w-md bg-white rounded-lg shadow-md p-8">
            <h1 class="text-2xl font-bold mb-6 text-center">Inscription</h1>

            {{ form_start(registrationForm) }}
                <div class="mb-4">
                    {{ form_label(registrationForm.email, 'Email', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.email, {attr: {class: 'w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>
                <div class="mb-4">
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe', {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {attr: {class: 'w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>
                <div class="mb-6">
                    <label class="flex items-center gap-2 text-sm text-gray-700">
                        {{ form_widget(registrationForm.agreeTerms) }}
                        J'accepte les conditions d'utilisation
                    </label>
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>
                <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 font-medium cursor-pointer">S'inscrire</button>
            {{ form_end(registrationForm) }}

            <p class="mt-4 text-center text-sm text-gray-600">
                Déjà un compte ? <a href="{{ path('app_login') }}" class="text-blue-500 hover:underline">Se connecter</a>
            </p>
        </div>
    </body>
</html>
