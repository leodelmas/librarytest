{# Fragment loaded via AJAX into the modal #}
<div>
    <div class="mb-4 flex items-center justify-between">
        <span class="inline-block rounded-lg py-1 px-3 text-xs font-medium"
              style="background-color: {{ userBook.status.colors[0] }}; color: {{ userBook.status.colors[1] }}">{{ userBook.status.label }}</span>
        <button data-action="note-modal#close" class="text-gray-400 hover:text-gray-700 cursor-pointer">{{ ux_icon('lucide:x', {class: 'w-5 h-5'}) }}</button>
    </div>

    <div class="flex gap-6">
        {% if userBook.book.coverUrl %}
            <img src="{{ userBook.book.coverUrl }}" alt="" class="w-32 flex-shrink-0 object-contain rounded">
        {% else %}
            <div class="w-32 flex-shrink-0 h-44 bg-gray-100 rounded flex items-center justify-center text-gray-400 text-xs">Pas de couverture</div>
        {% endif %}

        <div class="flex-1 min-w-0">
            <h2 class="text-xl font-bold leading-tight">{{ userBook.book.title }}</h2>
            {% if userBook.book.author %}
                <p class="text-gray-600 mt-1">{{ userBook.book.author }}</p>
            {% endif %}
            {% if userBook.book.firstPublishYear %}
                <p class="text-gray-400 text-sm mt-1">{{ userBook.book.firstPublishYear }}</p>
            {% endif %}
        </div>
    </div>

    {% if userBook.book.description %}
        <div class="mt-5 text-sm text-gray-700 leading-relaxed border-t pt-4 max-h-64 overflow-y-auto">
            {{ userBook.book.description|nl2br }}
        </div>
    {% else %}
        <p class="mt-5 text-sm text-gray-400 border-t pt-4 italic">Aucune description disponible.</p>
    {% endif %}
</div>
