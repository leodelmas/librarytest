{% extends 'base.html.twig' %}

{% block title %}Ma collection{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.bubble.css" rel="stylesheet">
    <style>
        .ql-editor { min-height: 200px; font-size: 1.125rem; line-height: 1.75; }
        dialog::backdrop { background: rgba(0, 0, 0, 0.5); }
        dialog[open] { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); margin: 0; }
    </style>
{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-8" data-controller="note-modal">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold">Ma collection</h1>
        <a href="{{ path('book_search') }}" class="w-8 h-8 rounded-full bg-blue-500 text-white hover:bg-blue-700 hover:scale-110 active:scale-95 transition-all duration-150 flex items-center justify-center" title="Ajouter des livres">{{ ux_icon('lucide:plus', {class: 'w-4 h-4'}) }}</a>
    </div>

    {% if userBooks is empty %}
        <p class="text-center text-gray-500 py-8">Aucun livre dans votre collection. <a href="{{ path('book_search') }}" class="text-blue-500 hover:underline">Rechercher des livres</a></p>
    {% else %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for userBook in userBooks %}
        <div class="bg-white rounded-lg overflow-hidden shadow-md flex flex-col"
             data-controller="book-collection"
             data-book-collection-id-value="{{ userBook.id }}"
             data-book-collection-url-value="{{ path('book_delete', {id: userBook.id}) }}"
             data-book-collection-status-url-value="{{ path('book_status', {id: userBook.id}) }}">
            {% if userBook.book.coverUrl %}
                <img src="{{ userBook.book.coverUrl }}" alt="" class="w-full h-52 object-contain bg-gray-100" loading="lazy">
            {% else %}
                <div class="w-full h-52 bg-gray-100 flex items-center justify-center text-gray-400 text-sm">Pas de couverture</div>
            {% endif %}
            <div class="p-4 flex-1 flex flex-col">
                <h3 class="font-semibold text-base mb-1">{{ userBook.book.title }}</h3>
                {% if userBook.book.author %}
                    <p class="text-gray-600 text-sm">{{ userBook.book.author }}</p>
                {% endif %}
                {% if userBook.book.firstPublishYear %}
                    <p class="text-gray-400 text-xs mt-1">{{ userBook.book.firstPublishYear }}</p>
                {% endif %}
                <div class="mt-2">
                    <span data-book-collection-target="statusLabel"
                          class="inline-block rounded-lg py-1 px-3 text-xs font-medium"
                          style="background-color: {{ userBook.status.colors[0] }}; color: {{ userBook.status.colors[1] }}">{{ userBook.status.label }}</span>
                </div>
                <div class="mt-auto pt-3 flex items-center gap-2"
                     data-book-collection-target="statusWrap"
                     data-status="{{ userBook.status.value }}">
                    <button data-action="book-collection#changeStatus"
                            data-book-collection-target="statusBtn"
                            class="w-8 h-8 rounded-full hover:scale-110 active:scale-95 transition-all duration-150 flex items-center justify-center cursor-pointer"
                            style="background-color: {{ userBook.status.colors[0] }}; color: {{ userBook.status.colors[1] }}">
                        {% for s in enum('App\\Enum\\ReadingStatus').cases %}
                            <span data-status="{{ s.value }}" class="{{ userBook.status == s ? '' : 'hidden' }}">{{ ux_icon(s.icon, {class: 'w-4 h-4'}) }}</span>
                        {% endfor %}
                    </button>
                    <a href="{{ path('book_show', {id: userBook.id}) }}"
                       data-action="note-modal#open"
                       class="w-8 h-8 rounded-full bg-gray-200 text-gray-600 hover:scale-110 active:scale-95 transition-all duration-150 flex items-center justify-center cursor-pointer"
                       title="Détails">{{ ux_icon('lucide:book-open', {class: 'w-4 h-4'}) }}</a>
                    <a href="{{ path('book_note', {id: userBook.id}) }}"
                       data-action="note-modal#open"
                       class="w-8 h-8 rounded-full bg-gray-200 text-gray-600 hover:scale-110 active:scale-95 transition-all duration-150 flex items-center justify-center cursor-pointer"
                       title="Notes">{{ ux_icon('lucide:pencil', {class: 'w-4 h-4'}) }}</a>
                    <button
                        data-action="book-collection#delete"
                        data-book-collection-target="button"
                        class="w-8 h-8 rounded-full bg-red-200 text-red-600 hover:scale-110 active:scale-95 transition-all duration-150 flex items-center justify-center cursor-pointer"
                    >{{ ux_icon('lucide:minus', {class: 'w-4 h-4'}) }}</button>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    <dialog data-note-modal-target="dialog" data-action="click->note-modal#backdropClick"
            class="m-auto w-full max-w-2xl rounded-lg shadow-xl p-6 backdrop:bg-black/50">
        <div data-note-modal-target="body"></div>
    </dialog>
</div>
{% endblock %}
